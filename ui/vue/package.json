{
  "name": "@btech/vue-ui",
  "version": "0.1.0",
  "description": "Btech Design System - Vue 3 Component Library",
  "type": "module",
  "main": "./dist/btech-vue-ui.umd.cjs",
  "module": "./dist/btech-vue-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/btech-vue-ui.js",
      "require": "./dist/btech-vue-ui.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RamaMS06/btech-ui.git",
    "directory": "ui/vue"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'lint not configured yet'",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@btech/tokens": "workspace:*",
    "@btech/shared": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^14.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
