{
  "name": "@btech/tokens",
  "version": "0.2.1",
  "description": "Btech Design System - Design Tokens",
  "type": "module",
  "scripts": {
    "build": "tsx config/sd.config.ts",
    "clean": "rm -rf generated"
  },
  "exports": {
    "./css": "./generated/web/tokens.css",
    "./scss": "./generated/web/tokens.scss",
    "./js": {
      "import": "./generated/web/tokens.mjs",
      "types": "./generated/web/tokens.d.ts"
    },
    ".": {
      "import": "./generated/web/tokens.mjs",
      "types": "./generated/web/tokens.d.ts"
    },
    "./json": "./src/",
    "./json/primitive/*": "./src/primitive/*",
    "./json/semantic/*": "./src/semantic/*",
    "./json/component/*": "./src/component/*"
  },
  "files": [
    "generated/**",
    "src/**"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RamaMS06/btech-ui.git",
    "directory": "tokens"
  },
  "devDependencies": {
    "style-dictionary": "^4.0.0",
    "tsx": "^4.7.0"
  }
}
