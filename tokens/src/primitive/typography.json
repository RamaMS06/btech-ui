{
  "fontFamily": {
    "sans": { "$value": "Inter, ui-sans-serif, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
    "mono": { "$value": "JetBrains Mono, ui-monospace, Cascadia Code, monospace", "$type": "fontFamily" }
  },
  "fontSize": {
    "xs":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px — Caption, helper text" },
    "sm":   { "$value": "0.875rem", "$type": "dimension", "$description": "14px — Small labels, metadata" },
    "base": { "$value": "1rem",     "$type": "dimension", "$description": "16px — Body text" },
    "lg":   { "$value": "1.125rem", "$type": "dimension", "$description": "18px — Lead text" },
    "xl":   { "$value": "1.25rem",  "$type": "dimension", "$description": "20px — Section title" },
    "2xl":  { "$value": "1.5rem",   "$type": "dimension", "$description": "24px — Card title" },
    "3xl":  { "$value": "1.875rem", "$type": "dimension", "$description": "30px — Page title" },
    "4xl":  { "$value": "2.25rem",  "$type": "dimension", "$description": "36px — Hero title" }
  },
  "lineHeight": {
    "xs":   { "$value": "1rem",     "$type": "dimension", "$description": "16px — for text-xs" },
    "sm":   { "$value": "1.25rem",  "$type": "dimension", "$description": "20px — for text-sm" },
    "base": { "$value": "1.5rem",   "$type": "dimension", "$description": "24px — for text-base" },
    "lg":   { "$value": "1.75rem",  "$type": "dimension", "$description": "28px — for text-lg and text-xl" },
    "2xl":  { "$value": "2rem",     "$type": "dimension", "$description": "32px — for text-2xl" },
    "3xl":  { "$value": "2.25rem",  "$type": "dimension", "$description": "36px — for text-3xl" },
    "4xl":  { "$value": "2.5rem",   "$type": "dimension", "$description": "40px — for text-4xl" }
  },
  "fontWeight": {
    "light":    { "$value": 300, "$type": "fontWeight", "$description": "Decorative" },
    "normal":   { "$value": 400, "$type": "fontWeight", "$description": "Body text" },
    "medium":   { "$value": 500, "$type": "fontWeight", "$description": "Labels, emphasis" },
    "semibold": { "$value": 600, "$type": "fontWeight", "$description": "Headings, buttons" },
    "bold":     { "$value": 700, "$type": "fontWeight", "$description": "Strong emphasis" }
  },
  "letterSpacing": {
    "tighter": { "$value": "-0.05em", "$type": "dimension", "$description": "Large headings" },
    "tight":   { "$value": "-0.025em","$type": "dimension", "$description": "Headings" },
    "normal":  { "$value": "0em",     "$type": "dimension", "$description": "Body" },
    "wide":    { "$value": "0.025em", "$type": "dimension", "$description": "Small caps, labels" },
    "wider":   { "$value": "0.05em",  "$type": "dimension", "$description": "Overline text" }
  }
}
