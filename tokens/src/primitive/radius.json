{
  "radius": {
    "base":  { "$value": "0.625rem", "$type": "dimension", "$description": "10px — base radius, --radius" },
    "none":  { "$value": "0",        "$type": "dimension" },
    "sm":    { "$value": "0.375rem", "$type": "dimension", "$description": "6px — calc(var(--radius) - 4px)" },
    "md":    { "$value": "0.5rem",   "$type": "dimension", "$description": "8px — calc(var(--radius) - 2px)" },
    "lg":    { "$value": "0.625rem", "$type": "dimension", "$description": "10px — var(--radius)" },
    "xl":    { "$value": "0.875rem", "$type": "dimension", "$description": "14px — calc(var(--radius) + 4px)" },
    "2xl":   { "$value": "1.125rem", "$type": "dimension", "$description": "18px — calc(var(--radius) + 8px)" },
    "full":  { "$value": "9999px",   "$type": "dimension" }
  }
}
