{
  "$description": "Semantic spacing aliases for common component patterns",

  "content": {
    "xs": { "$value": "{spacing.1}",  "$type": "dimension", "$description": "4px — tight padding" },
    "sm": { "$value": "{spacing.2}",  "$type": "dimension", "$description": "8px — compact padding" },
    "md": { "$value": "{spacing.4}",  "$type": "dimension", "$description": "16px — default padding" },
    "lg": { "$value": "{spacing.6}",  "$type": "dimension", "$description": "24px — relaxed padding" },
    "xl": { "$value": "{spacing.8}",  "$type": "dimension", "$description": "32px — spacious padding" }
  },
  "gap": {
    "xs": { "$value": "{spacing.1}",  "$type": "dimension" },
    "sm": { "$value": "{spacing.2}",  "$type": "dimension" },
    "md": { "$value": "{spacing.3}",  "$type": "dimension" },
    "lg": { "$value": "{spacing.4}",  "$type": "dimension" },
    "xl": { "$value": "{spacing.6}",  "$type": "dimension" }
  }
}
