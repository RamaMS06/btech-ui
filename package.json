{
  "name": "btech-ui",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:tokens": "turbo run build --filter=@btech/tokens",
    "flutter:pub-get": "cd ui/flutter && flutter pub get",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "turbo run dev",
    "flutter:test": "cd ui/flutter && flutter test",
    "flutter:analyze": "cd ui/flutter && flutter analyze",
    "flutter:golden-update": "cd ui/flutter && flutter test --update-goldens",
    "changeset": "changeset",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
