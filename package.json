{
  "name": "btech-ui",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "build:tokens": "pnpm --filter @btech/tokens run build",
    "flutter:pub-get": "cd ui/flutter && flutter pub get",
    "test": "pnpm -r run build && pnpm -r run --if-present test",
    "lint": "pnpm -r run --if-present lint",
    "typecheck": "pnpm -r run build && pnpm -r run --if-present typecheck",
    "clean": "pnpm -r run --if-present clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm -r --parallel run --if-present dev",
    "flutter:test": "cd ui/flutter && flutter test",
    "flutter:analyze": "cd ui/flutter && flutter analyze",
    "flutter:golden-update": "cd ui/flutter && flutter test --update-goldens",
    "changeset": "changeset",
    "release": "pnpm -r run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
